{
  "name": "uniform-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "pnpm --filter @uniform-ts/playground dev",
    "build": "pnpm --filter @uniform-ts/core build",
    "build:watch": "pnpm --filter @uniform-ts/core dev",
    "test": "pnpm --filter @uniform-ts/core test",
    "lint": "pnpm -r lint",
    "format": "pnpx prettier --write '{apps,packages}/**/*.{ts,tsx,js,jsx,css,scss,html}'",
    "docs:dev": "pnpm --filter docs run start",
    "docs:build": "pnpm --filter docs run build",
    "docs:serve": "pnpm --filter docs run serve"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "semver": "^7.7.4"
  }
}
